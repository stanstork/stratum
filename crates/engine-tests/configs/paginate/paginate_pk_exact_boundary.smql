// Pagination: PK strategy - batch_size exactly equals row count
//
// actor has 200 rows; batch_size=200 means exactly 1 full batch.
// The producer must still fetch a second (empty) page to detect end-of-data.
// Catches "off-by-one at last-page boundary" bugs where the producer exits
// one batch early because the final page returns exactly batch_size rows.

define {
    mysql_url    = env("MYSQL_URL", "mysql://sakila_user:qwerty123@localhost:3306/sakila")
    postgres_url = env("POSTGRES_URL", "postgres://user:password@localhost:5432/testdb")
}

connection "src" { driver = "mysql"    url = define.mysql_url    }
connection "dst" { driver = "postgres" url = define.postgres_url }

pipeline "pk_exact_boundary" {
    from { connection = connection.src  table = "actor" }
    to   { connection = connection.dst  table = "actor" }

    paginate {
        strategy = "pk"
        cursor   = "actor.actor_id"
    }

    settings {
        create_missing_tables = true
        batch_size            = 200
    }
}
