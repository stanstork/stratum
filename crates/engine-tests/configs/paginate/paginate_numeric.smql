// Pagination: NUMERIC strategy on a non-unique column with a tie-breaker
//
// Uses the composite WHERE clause:
//   (staff_id > :val) OR (staff_id = :val AND payment_id > :last_id)
//   ORDER BY staff_id ASC, payment_id ASC LIMIT n
//
// Sakila payment.staff_id is TINYINT UNSIGNED with only 2 distinct values (1, 2):
//   ~8,000 rows per staff member - every page boundary falls inside a
//   duplicate-value run, making this a genuine test of tie-breaker correctness.
//
// 16,044 payment rows, batch_size=1000 -> 16 full pages + 1 partial.
//
// Requirements:
//   cursor     = non-unique numeric column (staff_id)
//   tiebreaker = unique PK column (payment_id) - disambiguates equal cursor values

define {
    mysql_url    = env("MYSQL_URL", "mysql://sakila_user:qwerty123@localhost:3306/sakila")
    postgres_url = env("POSTGRES_URL", "postgres://user:password@localhost:5432/testdb")
}

connection "src" { driver = "mysql"    url = define.mysql_url    }
connection "dst" { driver = "postgres" url = define.postgres_url }

pipeline "paginate_payment_numeric" {
    from { connection = connection.src  table = "payment" }
    to   { connection = connection.dst  table = "payment" }

    paginate {
        strategy   = "numeric"
        cursor     = "payment.staff_id"
        tiebreaker = "payment.payment_id"
    }

    settings {
        create_missing_tables = true
        batch_size            = 1000
    }
}
