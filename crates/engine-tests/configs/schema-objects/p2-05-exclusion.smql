// =============================================================================
// Phase 2 Test 05 - Exclusion Patterns
// =============================================================================
//
// WHAT THIS TESTS:
//   - Tables matching exclude patterns are not created or migrated
//   - Pattern "payment*" excludes the payment table from the graph
//   - Exact name "rental" excluded despite being reachable from customer
//   - Remaining FK graph is still created correctly
//
// ROOT TABLE: customer (FK graph includes address, city, country, rental, payment)
//
// EXCLUDED:
//   "payment"   -- exact match
//   "rental"    -- exact match
//
// TABLES EXPECTED:
//   country, city, address, customer
//
// TABLES MUST NOT APPEAR:
//   payment, rental
//
// RUN:
//   cargo run -p cli -- plan -c dev-fixtures/configs/phase2/p2-05-exclusion.smql
//
// VERIFY:
//   \dt
//   SELECT COUNT(*) FROM payment;  -- should fail (excluded)
//   SELECT COUNT(*) FROM rental;   -- should fail (excluded)
//   SELECT COUNT(*) FROM customer; -- should succeed (schema_only -> 0 rows)
//
// =============================================================================

define {
    mysql_url    = env("MYSQL_URL", "mysql://sakila_user:qwerty123@localhost:3306/sakila")
    postgres_url = env("POSTGRES_URL", "postgres://user:password@localhost:5432/testdb")
}

connection "src" {
    driver = "mysql"
    url    = define.mysql_url
}

connection "dst" {
    driver = "postgres"
    url    = define.postgres_url
}

pipeline "customer_no_transactions" {
    from {
        connection = connection.src
        table      = "customer"

        with references {
            data    = schema_only
            depth   = all
            exclude = ["payment", "rental", "store", "staff"]
        }
    }

    to {
        connection = connection.dst
    }

    settings {
        batch_size = 500
    }
}
