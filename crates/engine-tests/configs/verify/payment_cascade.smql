// Verify: cascade migration - payment + FK dependencies
//
// Source table: payment (root)
// Cascade depth 1 discovers: customer, staff, rental
//
// Each source batch (payment rows) is accompanied by rows for the FK-referenced
// tables. The receipt stores `rows_per_batch` per destination table, capturing
// how many customer/staff/rental rows were produced alongside each payment batch.
// Verify uses those exact counts to reproduce identical batch boundaries.
//
// Interesting aspects:
//   - payment.amount     DECIMAL(5,2)
//   - payment.payment_date DATETIME -> TIMESTAMP
//   - customer.active   TINYINT(1) -> BOOLEAN
//   - rental.rental_date DATETIME
//   - staff.picture     BLOB (nullable)

define {
    mysql_url    = env("MYSQL_URL", "mysql://sakila_user:qwerty123@localhost:3306/sakila")
    postgres_url = env("POSTGRES_URL", "postgres://user:password@localhost:5432/testdb")
}

connection "src" { driver = "mysql"    url = define.mysql_url    }
connection "dst" { driver = "postgres" url = define.postgres_url }

pipeline "migrate_payment" {
    from {
        connection = connection.src
        table      = "payment"

        with references {
            data  = cascade
            depth = 1
        }
    }

    to { connection = connection.dst }

    settings {
        create_missing_tables = true
        batchz_size            = 100
    }
}
