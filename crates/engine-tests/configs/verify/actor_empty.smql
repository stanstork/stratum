// Verify: empty result set (filter matches zero rows)
//
// A WHERE predicate that no actor satisfies (actor_id > 99999) produces
// an empty migration: 0 rows written, 0 batches in the receipt.
//
// Verify must handle a receipt with no batches gracefully - the verifier
// loop should exit immediately and return OK rather than panicking or
// claiming a mismatch.

define {
    mysql_url    = env("MYSQL_URL", "mysql://sakila_user:qwerty123@localhost:3306/sakila")
    postgres_url = env("POSTGRES_URL", "postgres://user:password@localhost:5432/testdb")
}

connection "src" { driver = "mysql"    url = define.mysql_url    }
connection "dst" { driver = "postgres" url = define.postgres_url }

pipeline "verify_actor_empty" {
    from { connection = connection.src  table = "actor" }
    to   { connection = connection.dst  table = "actor" }

    where "no_match" {
        actor.actor_id > 99999
    }

    settings {
        create_missing_tables = true
    }
}
