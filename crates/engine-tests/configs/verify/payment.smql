// Verify: payment table - DECIMAL, TIMESTAMP, nullable INT
//
// Sakila payment columns:
//   payment_id   SMALLINT PK
//   customer_id  SMALLINT (FK)
//   staff_id     TINYINT  (FK)
//   rental_id    INT      (nullable, FK)
//   amount       DECIMAL(5,2)
//   payment_date DATETIME
//   last_update  TIMESTAMP
//
// 16,044 rows. Exercises DECIMAL and DATETIME canonical encoding.

define {
    mysql_url    = env("MYSQL_URL", "mysql://sakila_user:qwerty123@localhost:3306/sakila")
    postgres_url = env("POSTGRES_URL", "postgres://user:password@localhost:5432/testdb")
}

connection "src" { driver = "mysql"    url = define.mysql_url    }
connection "dst" { driver = "postgres" url = define.postgres_url }

pipeline "migrate_payment" {
    from { connection = connection.src  table = "payment" }
    to   { connection = connection.dst  table = "payment" }

    settings {
        create_missing_tables = true
        batch_size            = 200
    }
}
