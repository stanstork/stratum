// Verify: actor with warn validation - all rows still migrated
//
// `warn` fires a warning for rows failing the check but does NOT skip them.
// Every row reaches the destination unchanged. Verify confirms the full row
// count is present and hashes match.
//
// Demonstrates: warn != skip; verify passes with full dataset.

define {
    mysql_url    = env("MYSQL_URL", "mysql://sakila_user:qwerty123@localhost:3306/sakila")
    postgres_url = env("POSTGRES_URL", "postgres://user:password@localhost:5432/testdb")
}

connection "src" { driver = "mysql"    url = define.mysql_url    }
connection "dst" { driver = "postgres" url = define.postgres_url }

pipeline "migrate_actor_warned" {
    from { connection = connection.src  table = "actor" }
    to   { connection = connection.dst  table = "actor" }

    validate {
        warn "has_last_name" {
            check   = actor.last_name != ""
            message = "Actor has no last name"
        }
    }

    settings {
        create_missing_tables = true
        batch_size            = 50
    }
}
