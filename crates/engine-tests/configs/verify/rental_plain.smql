// Verify: rental table - nullable column hashing
//
// rental.return_date is DATETIME NULL; many rows have NULL there (rentals
// not yet returned). Ensures the hasher encodes NULL consistently so that
// NULL-heavy rows produce stable, reproducible hashes on both source and
// destination sides.
//
// rental: 16,044 rows, batch_size=500 -> ~33 pages.
// ignore_constraints avoids FK failures (customer/inventory/staff not migrated).

define {
    mysql_url    = env("MYSQL_URL", "mysql://sakila_user:qwerty123@localhost:3306/sakila")
    postgres_url = env("POSTGRES_URL", "postgres://user:password@localhost:5432/testdb")
}

connection "src" { driver = "mysql"    url = define.mysql_url    }
connection "dst" { driver = "postgres" url = define.postgres_url }

pipeline "verify_rental_plain" {
    from { connection = connection.src  table = "rental" }
    to   { connection = connection.dst  table = "rental" }

    paginate {
        strategy = "pk"
        cursor   = "rental.rental_id"
    }

    settings {
        create_missing_tables = true
        ignore_constraints    = true
        batch_size            = 500
    }
}
