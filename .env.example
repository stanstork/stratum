# Copy this file to `.env` and adjust for your environment, then run any example
# with `-e .env`, e.g.:
#
#   stratum apply -c examples/configs/schema.smql -e .env
#
# The values below match the local test setup described in the README
# (Sakila on MySQL, an empty target DB on PostgreSQL). They are local-only
# development credentials.

MYSQL_URL=mysql://sakila_user:qwerty123@localhost:3306/sakila
POSTGRES_URL=postgres://user:password@localhost:5432/testdb
